ip access-list extended RESTRICT_VLAN
 permit tcp any 10.1.60.0 0.0.0.255 established
 deny ip any 10.1.60.0 0.0.0.255
 deny ip any 10.1.10.0 0.0.0.255
 deny ip any 10.1.20.0 0.0.0.255
 deny ip any 10.1.30.0 0.0.0.255
 deny ip any 10.1.40.0 0.0.0.255
 permit ip any any
!
interface Vlan10
 ip access-group RESTRICT_VLAN in
interface Vlan20
 ip access-group RESTRICT_VLAN in
interface Vlan30
 ip access-group RESTRICT_VLAN in
interface Vlan40
 ip access-group RESTRICT_VLAN in
exit
!
