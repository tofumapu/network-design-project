hostname DN-SWL3-BACKUP
!
interface GigabitEthernet1/0/1
 description Uplink to Core Router DN (Backup)
 no switchport
 ip address 10.3.2.2 255.255.255.252
 no shutdown
 ip ospf cost 100
!
ip routing
!
vlan 10
 name Ketoan
vlan 20
 name QuanLyRuiRo
vlan 30
 name IT
vlan 40
 name WiFi_CTY
vlan 60
 name Management
!
interface vlan10
 ip address 10.3.10.3 255.255.255.0
 standby version 2
 standby 10 ip 10.3.10.1
 standby 10 priority 100
 no standby 10 preempt
!
interface vlan20
 ip address 10.3.20.3 255.255.255.0
 standby version 2
 standby 20 ip 10.3.20.1
 standby 20 priority 100
 no standby 20 preempt
!
interface vlan30
 ip address 10.3.30.3 255.255.255.0
 standby version 2
 standby 30 ip 10.3.30.1
 standby 30 priority 100
 no standby 30 preempt
!
interface vlan40
 ip address 10.3.40.3 255.255.255.0
 standby version 2
 standby 40 ip 10.3.40.1
 standby 40 priority 100
 no standby 40 preempt
!
interface vlan60
 ip address 10.3.60.3 255.255.255.0
 standby version 2
 standby 60 ip 10.3.60.1
 standby 60 priority 100
 no standby 60 preempt
!
router ospf 1
 router-id 10.10.10.10
 log-adjacency-changes
 network 10.3.10.0 0.0.0.255 area 0
 network 10.3.20.0 0.0.0.255 area 0
 network 10.3.30.0 0.0.0.255 area 0
 network 10.3.40.0 0.0.0.255 area 0
 network 10.3.60.0 0.0.0.255 area 0
 network 10.3.1.0 0.0.0.3 area 0
 network 10.3.2.0 0.0.0.3 area 0
!
ip route 0.0.0.0 0.0.0.0 10.3.2.1 10
!
ip dhcp excluded-address 10.3.10.1 10.3.10.120
ip dhcp excluded-address 10.3.20.1 10.3.20.120
ip dhcp excluded-address 10.3.30.1 10.3.30.120
ip dhcp excluded-address 10.3.40.1 10.3.40.120
ip dhcp excluded-address 10.3.60.1 10.3.60.120
!
ip dhcp pool KE-TOAN_DN
 network 10.3.10.0 255.255.255.0
 default-router 10.3.10.1
 dns-server 8.8.8.8
ip dhcp pool RISK-MGMT_DN
 network 10.3.20.0 255.255.255.0
 default-router 10.3.20.1
 dns-server 8.8.8.8
ip dhcp pool IT-DEPT_DN
 network 10.3.30.0 255.255.255.0
 default-router 10.3.30.1
 dns-server 8.8.8.8
ip dhcp pool WF-COMPANY_DN
 network 10.3.40.0 255.255.255.0
 default-router 10.3.40.1
 dns-server 8.8.8.8
ip dhcp pool NETWORK-MGMT_DN
 network 10.3.60.0 255.255.255.0
 default-router 10.3.60.1
 dns-server 8.8.8.8
!
spanning-tree mode rapid-pvst
spanning-tree vlan 10,20,30,40,60 root secondary
