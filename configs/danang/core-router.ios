hostname DN-CORE-ROUTER
!
interface GigabitEthernet0/0
 description Uplink to SWL3-Main DN
 ip address 10.3.1.1 255.255.255.252
 duplex auto
 speed auto
 no shutdown
!
interface GigabitEthernet0/1
 description Uplink to SWL3-Backup DN
 ip address 10.3.2.1 255.255.255.252
 duplex auto
 speed auto
 no shutdown
!
interface Serial0/0/1
 description WAN Link to ISP
 ip address 10.3.0.2 255.255.255.0
 no shutdown
!
ip route 0.0.0.0 0.0.0.0 10.3.0.1
!
router ospf 1
 router-id 8.8.8.8
 log-adjacency-changes
 network 10.3.1.0 0.0.0.3 area 0
 network 10.3.2.0 0.0.0.3 area 0
 network 10.3.0.0 0.0.0.255 area 0
 default-information originate
