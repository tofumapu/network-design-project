hostname HN-SWL3-BACKUP
!
ip routing
!
vlan 10
 name Ketoan
vlan 20
 name QuanLyRuiRo
vlan 30
 name IT
vlan 40
 name WiFi_CTY
vlan 50
 name WiFi_Guest
vlan 60
 name Management
!
interface vlan10
 ip address 10.4.10.3 255.255.255.0
 standby version 2
 standby 10 ip 10.4.10.1
 standby 10 priority 100
 no standby 10 preempt
!
interface vlan20
 ip address 10.4.20.3 255.255.255.0
 standby version 2
 standby 20 ip 10.4.20.1
 standby 20 priority 100
 no standby 20 preempt
!
interface vlan30
 ip address 10.4.30.3 255.255.255.0
 standby version 2
 standby 30 ip 10.4.30.1
 standby 30 priority 100
 no standby 30 preempt
!
interface vlan40
 ip address 10.4.40.3 255.255.255.0
 standby version 2
 standby 40 ip 10.4.40.1
 standby 40 priority 100
 no standby 40 preempt
!
interface vlan50
 ip address 10.4.50.3 255.255.255.0
 standby version 2
 standby 50 ip 10.4.50.1
 standby 50 priority 100
 no standby 50 preempt
!
interface vlan60
 ip address 10.4.60.3 255.255.255.0
 standby version 2
 standby 60 ip 10.4.60.1
 standby 60 priority 100
 no standby 60 preempt
!
interface GigabitEthernet1/0/1
 description Uplink to Backup Router HN
 no switchport
 ip address 10.4.2.2 255.255.255.252
 ip ospf cost 100
!
router ospf 1
 router-id 7.7.7.7
 log-adjacency-changes
 network 10.4.10.0 0.0.0.255 area 1
 network 10.4.20.0 0.0.0.255 area 1
 network 10.4.30.0 0.0.0.255 area 1
 network 10.4.40.0 0.0.0.255 area 1
 network 10.4.50.0 0.0.0.255 area 1
 network 10.4.60.0 0.0.0.255 area 1
 network 10.4.1.0 0.0.0.3 area 1
 network 10.4.2.0 0.0.0.3 area 1
!
spanning-tree vlan 1-4094 root secondary
!
ip dhcp excluded-address 10.4.10.1 10.4.10.120
ip dhcp excluded-address 10.4.20.1 10.4.20.120
ip dhcp excluded-address 10.4.30.1 10.4.30.120
ip dhcp excluded-address 10.4.40.1 10.4.40.120
ip dhcp excluded-address 10.4.60.1 10.4.60.120
!
ip dhcp pool KE-TOAN_HN
 network 10.4.10.0 255.255.255.0
 default-router 10.4.10.1
 dns-server 8.8.8.8
!
ip dhcp pool RISK-MGMT_HN
 network 10.4.20.0 255.255.255.0
 default-router 10.4.20.1
 dns-server 8.8.8.8
!
ip dhcp pool IT-DEPT_HN
 network 10.4.30.0 255.255.255.0
 default-router 10.4.30.1
 dns-server 8.8.8.8
!
ip dhcp pool WF-COMPANY_HN
 network 10.4.40.0 255.255.255.0
 default-router 10.4.40.1
 dns-server 8.8.8.8
!
ip dhcp pool NETWORK-MGMT_HN
 network 10.4.60.0 255.255.255.0
 default-router 10.4.60.1
 dns-server 8.8.8.8
